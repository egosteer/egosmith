# =============================================================================
# EgoSmith — data, weights, and runtime artifacts (do not commit large files)
# =============================================================================

# model weights & checkpoints (download on demand; see the README setup scripts)
/weights/
/checkpoints/
**/weights/
**/checkpoints/
*.pth
*.pt
*.ckpt
*.safetensors
*.onnx
*.engine
*.trt

# datasets, archives, and pickled assets
/datasets/
/dataset*/
*.zip
*.pkl
# _DATA = MANO assets (obtained separately from the MANO site; not shipped)
/_DATA/

# pipeline run outputs and temporaries
/batch_runs/
/.tmp/
experiments/
logs/
logs*
pred_vis/
eval_vis_*/
*_trainset_export/

# local videos (the small demo clip in example_video/ stays tracked)
*.mov

